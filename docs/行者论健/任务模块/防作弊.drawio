          <mxGeometry x="789" y="50" width="301" height="190" as="geometry" />
        </mxCell>
        <mxCell id="Yot8EYofxVsVi1BPe_l9-92" value="&lt;h1&gt;学生打开小程序运动,从路径1出发到教学楼范围需要手动打卡，手动打开可以防止上课时要求人脸出发声音提示，其他范围自动打卡，进入指定范围自动触发打卡,打卡时有概率触发人脸验证，学生需要在规定时间内上传人像。学生离开学校200M范围后运动就不需要打卡了；学生可以随意选择路径，如路径2，每天只需要打开不同地方，合计打卡2 次，就算运动有效。学生每日成绩根据，运动是否有效，时长，距离，速度计算。&amp;nbsp;&lt;/h1&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" vertex="1" parent="Yot8EYofxVsVi1BPe_l9-42">
          <mxGeometry x="1600" y="68" width="420" height="550" as="geometry" />
        </mxCell>
